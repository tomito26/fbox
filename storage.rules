rules_version = '2';

// Firebase Storage security rules for fbox avatars.
//
// To apply these rules:
//   • Firebase Console → Storage → Rules → paste + Publish, OR
//   • add   "storage": { "rules": "storage.rules" }   to firebase.json and run
//     `firebase deploy --only storage`.
//
// Until these are published (and Storage is enabled for the project), avatar
// uploads fail with `storage/unauthorized` — the Profile page surfaces that as
// a friendly error banner rather than hanging.

service firebase.storage {
  match /b/{bucket}/o {

    // Profile avatars live at avatars/{uid}. Anyone signed in can read them
    // (so the navbar/profile can show them), but a user may only write or
    // delete their own, and only small image files.
    match /avatars/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Everything else is locked down by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
